{
  "name": "@os-eco/trellis-cli",
  "version": "0.1.0",
  "description": "Git-native specs, plans, and handoff artifacts for the os-eco toolchain",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RogerNavelsaker/trellis.git"
  },
  "homepage": "https://github.com/RogerNavelsaker/trellis#readme",
  "bugs": {
    "url": "https://github.com/RogerNavelsaker/trellis/issues"
  },
  "keywords": [
    "os-eco",
    "trellis",
    "cli",
    "git-native",
    "workflow",
    "planning"
  ],
  "bin": {
    "trellis": "src/index.ts",
    "tl": "src/index.ts"
  },
  "scripts": {
    "show-manifest": "bun --eval \"console.log(await Bun.file('nix/package-manifest.json').text())\"",
    "sync:bun-deps": "bunx bun2nix --lock-file bun.lock --output-file bun.nix"
  },
  "dependencies": {
    "chalk": "^5.6.0",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.5",
    "@types/bun": "^1.3.1",
    "bun2nix": "2.0.8",
    "typescript": "^5.9.2"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
